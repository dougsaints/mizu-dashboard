# =====================================================================
# Mizu Cloud — Variáveis de ambiente
# Copie para .env.local e preencha com os valores reais do seu Supabase
# (Settings → API no dashboard do projeto)
# =====================================================================

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_PUBLIC_KEY

# ID do tenant Sushi Mizú criado pelo seed.sql
# (rode `select id from tenants where slug='sushi-mizu';` no SQL Editor)
VITE_MIZU_TENANT_ID=
